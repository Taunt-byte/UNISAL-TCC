    const subscription = Dimensions.addEventListener("change", updateLayout);
    updateLayout();
    return () => subscription.remove();
  }, []);

  return (
    <ParallaxScrollView
      headerBackgroundColor={{ light: "#E0F2FE", dark: "#1E293B" }}
