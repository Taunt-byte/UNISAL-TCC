      <ThemedView style={styles.dataContainer}>
        <ThemedText type="subtitle" style={styles.dataLabel}>
          🌡️ Temperatura Atual:
        </ThemedText>
        <ThemedText style={styles.dataValue}>
          {temperature !== null ? `${temperature} °C` : "Carregando..."}
        </ThemedText>

        <ThemedText type="subtitle" style={styles.dataLabel}>
          💧 Umidade Atual:
        </ThemedText>
        <ThemedText style={styles.dataValue}>
          {humidity !== null ? `${humidity} %` : "Carregando..."}
        </ThemedText>
      </ThemedView>

      <ThemedView style={[styles.stepsContainer, isSmallScreen && styles.stepsContainerColumn]}>
        {steps.map((step, index) => (
          <View
            key={index}
            style={[styles.card, isSmallScreen && styles.cardSmall]}
          >
            <ThemedText type="subtitle" style={styles.cardTitle}>
              {step.title}
            </ThemedText>
            <ThemedText style={styles.cardText}>{step.description}</ThemedText>
          </View>
        ))}
      </ThemedView>
    </ParallaxScrollView>
  );
}

